PORT=3000
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
DATA_DIR=./data
PILOT_PROJECT_NAME=OpenSpace Pilot
# Set these only for the first startup, then remove them from the deployment.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-12-character-minimum-password
# Provider auth: either a static token, or email+password for auto-refresh (preferred — login JWTs expire)
# MIMARAI_API_TOKEN=provider-service-token
# MIMARAI_EMAIL=service-account@example.com
# MIMARAI_PASSWORD=service-account-password
